{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "app/exports/index.ts",
    "app/exports/charts/index.ts",
    "app/exports/hooks/index.ts",
    "app/exports/utils/index.ts",
    "app/exports/core.ts",
    "app/exports/client.ts",
    "app/index.ts",
    "app/config-types.ts",
    "app/types/index.ts",
    "app/types/ui-props.ts",
    "app/statistics/formatters.ts",
    "app/statistics/utils.ts",
    "app/locales/locales.ts",
    "app/formatters.ts",
    "app/config-utils.ts"
  ],
  "out": "docs/api",
  "theme": "default",
  "readme": "README.md",
  "name": "Vizualni Admin API Documentation",
  "includeVersion": true,
  "excludeExternals": true,
  "excludeNotDocumented": false,
  "excludePrivate": true,
  "excludeProtected": false,
  "disableSources": false,
  "sourceLinkTemplate": "https://github.com/acailic/vizualni-admin/blob/{gitRevision}/{path}#L{line}",
  "gitRevision": "main",
  "tsconfig": "tsconfig.json",
  "defaultCategory": "Other",
  "categoryOrder": [
    "Exports",
    "Chart Components",
    "React Hooks",
    "Utilities",
    "Core API",
    "Client",
    "Configuration Types",
    "UI Types",
    "Locale Utilities",
    "Formatters",
    "Statistics",
    "*"
  ],
  "sort": ["source-order"],
  "kindSortOrder": [
    "Class",
    "Interface",
    "TypeAlias",
    "Variable",
    "Function",
    "Enum",
    "Namespace"
  ],
  "categorizeByGroup": true,
  "commentStyle": "jsdoc",
  "searchInComments": true,
  "preserveLinkText": true,
  "hideGenerator": true
}
