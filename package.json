    "fs-extra": "^10.0.0",
    "gh-pages": "^6.0.0",
    "graphql": "^16.12.0",
    "husky": "8",
    "import-move-codemod": "^0.0.3",
    "jest-axe": "^9.0.0",
    "knip": "^5.42.0",
    "madge": "^6.1.0",
