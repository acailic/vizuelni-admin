{
  "name": "vizualni-admin",
  "version": "1.0.0",
  "description": "Serbian Open Data Visualization Tool based on visualize-admin",
  "packageManager": "yarn@1.22.22",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acailic/vizualni-admin.git"
  },
  "author": {
    "name": "acailic",
    "email": "acailic@example.com"
  },
  "license": "BSD-3-Clause",
  "private": true,
  "scripts": {
    "dev": "preconstruct dev && NODE_OPTIONS=\"--inspect --openssl-legacy-provider \" next ./app",
    "dev:ssl": "preconstruct dev && NODE_OPTIONS=\"--inspect --openssl-legacy-provider \" next dev --experimental-https ./app",
    "dev:mitmproxy": "preconstruct dev && HTTP_PROXY=http://localhost:8080 NODE_EXTRA_CA_CERTS=~/.mitmproxy/mitmproxy-ca-cert.pem GLOBAL_AGENT_ENVIRONMENT_VARIABLE_NAMESPACE='' NO_PROXY='localhost,127.0.0.1' next ./app",
    "dev:rollup": "rollup -c rollup.config.js --watch",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "docs:serve": "vitepress serve",
    "db:migrate:dev": "DATABASE_URL=postgres://postgres:password@localhost:5432/visualization_tool prisma db push",
    "db:migrate": "[ -z \"$DATABASE_URL\" ] && echo 'Bypassing database migration, DATABASE_URL not set' || prisma db push",
    "build": "yarn graphql:codegen && lingui compile && rollup -c rollup.config.js && yarn storybook:build && yarn generate-json-schema && cd app && next build",
    "build:static": "yarn graphql:codegen && lingui compile && yarn generate-json-schema && cd app && next build",
    "build:fast": "yarn graphql:codegen && lingui compile && next build ./app",
    "build:npm": "lingui compile",
    "deploy:gh-pages": "yarn build:static",
    "start": "yarn db:migrate && GLOBAL_AGENT_ENVIRONMENT_VARIABLE_NAMESPACE='' NO_PROXY='localhost,127.0.0.1' next start ./app -p $PORT",
    "typecheck": "tsc --noEmit -p ./app && tsc --noEmit -p ./embed",
    "lint": "eslint app",
    "knip": "npx knip --tags=-internal",
    "locales:extract": "lingui extract --clean; ./scripts/strip-locale-line-numbers.sh",
    "locales:compile": "lingui compile --verbose",
    "locales:sync": "dotenv -- accent sync --add-translations --merge-type=passive --order-by=key; yarn locales:extract # putting back file location comments",
    "locales:browse": "open 'https://accent.interactivethings.io/app/projects/584e1dfa-ff1f-4b26-8cac-07004c465134'",
    "docs:api": "typedoc --options typedoc.json --skipErrorChecking",
    "docs:api:dev": "typedoc --options typedoc.json --watch --skipErrorChecking",
    "docs:api:integrate": "node scripts/integrate-typedoc.js",
    "docs:api:build": "npm run docs:api && npm run docs:api:integrate",
    "docs:api:watch": "node scripts/watch-docs.js",
    "docs:build-with-api": "npm run docs:api:build && npm run docs:build",
    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "graphql:codegen:dev": "graphql-codegen --config codegen.yml --watch",
    "icons": "rm -f app/icons/components/*.tsx && svgr -d app/icons/components app/icons/svg",
    "images:optimize": "node scripts/optimize-images.js",
    "test": "cd ./app && vitest run",
    "test:watch": "cd ./app && vitest",
    "setup:dev": "yarn && yarn locales:compile && yarn db:migrate:dev",
    "postversion": "git push --follow-tags",
    "release:npm": "yarn build:npm && yarn publish app",
    "e2e:dev": "E2E_BASE_URL=http://localhost:3000 yarn playwright test",
    "e2e:dev:ssl": "E2E_BASE_URL=https://localhost:3000 yarn playwright test",
    "e2e:ui": "E2E_BASE_URL=http://localhost:3000 yarn playwright test --ui",
    "e2e:ui:ssl": "E2E_BASE_URL=https://localhost:3000 yarn playwright test --ui",
    "e2e": "playwright test",
    "cube": "NODE_ENV=development ts-node app/scripts/cube.ts",
    "dev:circular-deps": "madge --warning --extensions js,jsx,ts,tsx -b ./app -c ./app/pages/ --ts-config ./app/tsconfig.json | bun scripts/circular-deps-analysis.ts -",
    "github:codegen": "node k6/performance-tests/generate-github-actions.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o app/public/storybook",
    "chromatic": "npx chromatic --build-script-name storybook:build -o app/public/storybook",
    "compare-screenshots": "npx tsx scripts/compare-screenshots.ts",
    "generate-json-schema": "tsx -r dotenv/config app/scripts/generate-json-schema.ts",
    "wms-wmts-providers:scrape": "curl https://raw.githubusercontent.com/geoadmin/web-mapviewer/refs/heads/develop/packages/mapviewer/src/modules/menu/components/advancedTools/ImportCatalogue/external-providers.json | prettier --parser json > ./app/charts/map/wms-wmts-providers.json",
    "test:coverage": "cd ./app && vitest run --coverage",
    "test:accessibility": "cd ./app && vitest run --reporter=verbose --testNamePattern=\"a11y|accessibility\"",
    "test:visual": "npx playwright test --config=playwright.visual.config.ts",
    "test:integration": "cd ./app && vitest run --reporter=verbose --testNamePattern=\"integration\"",
    "test:all": "yarn test && yarn test:accessibility && yarn test:visual",
    "coverage:report": "cd ./app && vitest run --coverage --reporter=json > coverage-report.json",
    "coverage:check": "cd ./app && vitest run --coverage --run --reporter=verbose",
    "analyze": "cd ./app && npx bundle-analyzer",
    "benchmark": "cd ./app && vitest run benchmarks",
    "audit": "yarn audit",
    "quality-gates": "node scripts/quality-gates.js",
    "pre-commit": "yarn quality-gates",
    "fonts:optimize": "node scripts/optimize-fonts.js",
    "fonts:test": "node scripts/test-font-optimization.js",
    "fonts:report": "node scripts/optimize-fonts.js && echo '📊 Optimization report generated in app/public/static/fonts/optimized/'",
    "fonts:clean": "rm -rf app/public/static/fonts/optimized/ && echo '🧹 Cleaned optimized fonts'",
    "performance:test": "node scripts/test-performance.js",
    "performance:monitor": "echo '📊 Performance monitoring is now integrated in the app. Visit /performance to view metrics.'",
    "performance:lighthouse": "npx lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json --chrome-flags='--headless'",
    "performance:bundle": "cd app && npx bundle-analyzer",
    "pwa:manifest": "echo '✅ PWA manifest is available at /public/manifest.json'",
    "pwa:service-worker": "echo '✅ Service worker is available at /public/sw.js'",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.11.2",
    "@cozy/cli-tree": "^0.3.0",
    "@deck.gl/geo-layers": "^9.2.2",
    "@deck.gl/layers": "^9.2.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@juggle/resize-observer": "^3.4.0",
    "@mdxeditor/editor": "^3.51.0",
    "@mui/icons-material": "^7.3.5",
    "@mui/lab": "^7.0.1-beta.19",
    "@mui/material": "^7.3.5",
    "@mui/styles": "^6.4.8",
    "@mui/utils": "^7.3.5",
    "@rdfjs/namespace": "^2.0.1",
    "@reach/auto-id": "^0.18.0",
    "@sentry/nextjs": "^10.27.0",
    "@tpluscode/rdf-ns-builders": "^5.0.0",
    "@tpluscode/sparql-builder": "^3.0.1",
    "@types/iframe-resizer": "^4.0.0",
    "@urql/exchange-graphcache": "^8.1.0",
    "clipboard-polyfill": "^4.1.1",
    "core-js": "^3.15.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "fast-xml-parser": "^5.3.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.24",
    "graphql-tag": "^2.12.6",
    "html-to-image": "^1.11.13",
    "iframe-resizer": "^5.5.7",
    "immer": "^11.0.1",
    "meta-png": "^1.0.6",
    "next": "^14.2.26",
    "next-auth": "^4.24.13",
    "nextkit": "^3.4.3",
    "notistack": "^3.0.2",
    "rdf-cube-view-query": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-markdown": "^10.1.0",
    "react-string-replace": "^1.1.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "strict-event-emitter-types": "^2.0.0",
    "string-similarity-js": "^2.1.4",
    "superjson": "^2.2.6",
    "ts-brand": "^0.2.0",
    "ts-node": "^10.9.2",
    "ts-pattern": "^5.9.0",
    "typescript-lru-cache": "^2.0.0",
    "urql": "^5.0.1",
    "use-debounce": "^10.0.6",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^3.9.4",
