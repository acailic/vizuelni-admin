{
  "name": "vizuelni-admin-srbije",
  "version": "0.1.0",
  "private": true,
  "description": "Визуелни Административни Подаци Србије - Platform for visualization of Serbian administrative data",
  "keywords": [
    "serbia",
    "srbija",
    "opendata",
    "visualization",
    "administrative-data",
    "nextjs",
    "typescript",
    "tailwindcss"
  ],
  "homepage": "https://github.com/your-org/vizuelni-admin-srbije#readme",
  "bugs": {
    "url": "https://github.com/your-org/vizuelni-admin-srbije/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vizuelni-admin-srbije.git"
  },
  "author": "Your Organization <opendata@ite.gov.rs>",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:qa": "playwright test tests/e2e/qa-live.spec.ts --reporter=list",
    "prepare": "husky install",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@tanstack/react-query": "^5.24.0",
    "@tanstack/react-query-devtools": "^5.24.0",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "d3": "^7.8.5",
    "date-fns": "^3.3.1",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "lz-string": "^1.5.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "next-intl": "^3.11.0",
    "papaparse": "^5.5.3",
    "plotly.js-dist-min": "^3.4.0",
    "postcss": "^8.4.35",
    "prisma": "^5.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.12.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.0",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/d3": "^7.4.3",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20.11.19",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "@types/react-grid-layout": "^1.3.6",
    "@types/topojson-client": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.2.2",
    "playwright": "^1.58.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
