{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@vizualni/application": ["./packages/application/src/index.ts"],
      "@vizualni/application/*": ["./packages/application/src/*"],
      "@vizualni/charts": ["./packages/charts/src/index.ts"],
      "@vizualni/charts/*": ["./packages/charts/src/*"],
      "@vizualni/data": ["./packages/data/src/index.ts"],
      "@vizualni/datagov-client": [
        "./packages/infrastructure/datagov-client/src/index.ts"
      ],
      "@vizualni/datagov-client/*": [
        "./packages/infrastructure/datagov-client/src/*"
      ],
      "@vizualni/shared-kernel": ["./packages/shared-kernel/src/index.ts"],
      "@vizualni/shared-kernel/*": ["./packages/shared-kernel/src/*"],
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/types/*": ["./src/types/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/utils/*": ["./src/lib/utils/*"],
      "@/api/*": ["./src/lib/api/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next-dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
