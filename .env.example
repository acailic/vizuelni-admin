# ===================================
# Application Configuration
# ===================================

# Application Name
NEXT_PUBLIC_APP_NAME="Визуелни Административни Подаци Србије"

# Environment (development, production, test)
NODE_ENV=development

# Port (default: 3000)
PORT=3000

# ===================================
# Demo Mode (for Vercel free tier)
# ===================================

# Enable demo mode - uses in-memory storage instead of database
# Automatically enabled if DATABASE_URL is not set
# DEMO_MODE=true

# ===================================
# API Configuration
# ===================================

# Data.gov.rs API Base URL
NEXT_PUBLIC_DATA_GOV_API_URL=https://data.gov.rs/api/1

# API Version
NEXT_PUBLIC_DATA_GOV_API_VERSION=1

# API Timeout (in milliseconds)
API_TIMEOUT=30000

# API Retry Attempts
API_RETRY_ATTEMPTS=3

# ===================================
# Internationalization (i18n)
# ===================================

# Default Locale (sr-Cyrl, sr-Latn, en)
NEXT_PUBLIC_DEFAULT_LOCALE=sr-Cyrl

# Supported Locales
NEXT_PUBLIC_SUPPORTED_LOCALES=sr-Cyrl,sr-Latn,en

# ===================================
# Analytics (Privacy-Focused)
# ===================================

# Enable analytics tracking
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Analytics provider: 'plausible', 'umami', 'vercel', or 'none'
NEXT_PUBLIC_ANALYTICS_PROVIDER=none

# Plausible Analytics (recommended for privacy)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Umami Analytics (self-hosted option)
# NEXT_PUBLIC_UMAMI_URL=https://your-umami-instance.com
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id

# Vercel Analytics (automatic if deployed on Vercel)
# No configuration needed - uses @vercel/analytics

# Google Analytics ID (not recommended - not privacy-focused)
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# Matomo URL (Alternative to GA)
# NEXT_PUBLIC_MATOMO_URL=https://stats.data.gov.rs/

# Matomo Site ID
# NEXT_PUBLIC_MATOMO_SITE_ID=1

# ===================================
# Maps & Visualization (Optional)
# ===================================

# Mapbox Token (for advanced maps)
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# Google Maps API Key
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# ===================================
# Feature Flags
# ===================================

# Enable Dark Mode
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Enable Data Export
NEXT_PUBLIC_ENABLE_EXPORT=true

# Enable Advanced Visualizations
NEXT_PUBLIC_ENABLE_ADVANCED_VIZ=true

# ===================================
# Cache Configuration
# ===================================

# Cache TTL (in seconds)
CACHE_TTL=3600

# Enable Redis Cache (optional)
# REDIS_URL=redis://localhost:6379

# ===================================
# Security
# ===================================

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=https://data.gov.rs,https://hub.data.gov.rs

# Rate Limiting (requests per minute)
RATE_LIMIT_MAX=100

# ===================================
# Development & Debugging
# ===================================

# Enable Debug Mode
DEBUG=false

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Enable API Request Logging
API_LOGGING=false

# ===================================
# External Services (Optional)
# ===================================

# Sentry DSN (Error Tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Slack Webhook (Notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ===================================
# Performance
# ===================================

# Enable Image Optimization
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true

# Image Domains for Next.js Image Component
NEXT_PUBLIC_IMAGE_DOMAINS=data.gov.rs,stats.data.gov.rs

# ===================================
# Content & Metadata
# ===================================

# Site URL (for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site Description
NEXT_PUBLIC_SITE_DESCRIPTION="Платформа за визуелизацију административних података Републике Србије"

# Contact Email
NEXT_PUBLIC_CONTACT_EMAIL=opendata@ite.gov.rs

# Social Media Links
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/kancelarijaITE
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/kancelarija-ite/
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@OpenDataSrbija

# ===================================
# AI Testing (Stagehand)
# ===================================

# Base URL for tests (default: http://localhost:3001)
BASE_URL=http://localhost:3001

# --- LLM Provider Configuration ---
# Priority: GLM/z.ai > z.ai legacy > custom LLM > OpenAI

# GLM/z.ai Configuration (recommended)
GLM_API_KEY=
GLM_API_BASE=https://api.z.ai/api/coding/paas/v4
LEARNER_API_PROVIDER=glm
LEARNER_MODEL=glm-5

# z.ai Legacy Configuration
# ZAI_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/v1
# ZAI_MODEL=gpt-4o

# OpenAI Configuration (alternative)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Custom LLM Configuration (OpenAI-compatible endpoints)
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o

# Browserbase API Key (optional: cloud browser)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
