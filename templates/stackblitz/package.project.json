{
  "name": "vizuelni-admin-srbije-stackblitz",
  "version": "0.1.0",
  "private": true,
  "description": "StackBlitz-optimized configuration for vizuelni-admin-srbije",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --port 3001",
    "dev:stackblitz": "npm run prepare:stackblitz && npm run dev",
