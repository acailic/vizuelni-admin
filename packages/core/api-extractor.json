/**
 * Config file for API Extractor.  For more info, please visit: https://api-extractor.com
 */
{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  /**
   * Optionally specifies another JSON config file that this file extends from.  This provides a way for
   * standard settings to be shared across multiple projects.
   *
   * If the path starts with "./" or "../", the path is resolved relative to the folder of the file that it
   * references.
   *
   * For more info:  https://api-extractor.com/pages/setup/configure_api_extractor/
   */
  // "extends": "./shared/api-extractor-base.json"
  // "extends": "@microsoft/api-extractor/default"

  /**
   * (Required) Specifies the .d.ts file to be used as the starting point for analysis.  API Extractor
   * will analyze the symbols exported by this file.
   *
   * The path is resolved relative to the folder of the config file that contains the setting, if applied.
   *
   * DEFAULT VALUE: "dist/index.d.ts"
   */
  "mainEntryPointFilePath": "<projectFolder>/dist/index.d.ts",

  /**
   * The list of NPM packages whose exports should be treated as part of this package.
   *
   * Normally API Extractor looks for source code under the "src" folder, but for some projects
   * the source code may be in a different location.  The "bundledPackages" setting tells API Extractor
   * where to look for source code for the specified packages.
   *
   * DEFAULT VALUE: []
   */
  "bundledPackages": [],

  /**
   * Determines how the compiler will invoke the TypeScript compiler engine.
   *
   * DEFAULT VALUE: "local"
   */
  "compiler": {
    /**
     * Specifies the type of the TypeScript compiler.
     *
     * "local" - Use the TypeScript compiler that is installed locally in the project.
     * "advanced" - Advanced configuration options.
     *
     * DEFAULT VALUE: "local"
     */
    "tsconfigFilePath": "<projectFolder>/tsconfig.json"
  },

  /**
   * Configures how the API report file (*.api.md) will be generated.
   */
  "apiReport": {
    /**
     * (Required) Whether to generate an API report.
     *
     * DEFAULT VALUE: true
     */
    "enabled": true,

    /**
     * The filename for the API report files.  It will be combined with "reportFolder" or "reportTempFolder" to produce
     * a full file path.
     *
     * The path is resolved relative to the folder of the config file that contains the setting.
     *
     * DEFAULT VALUE: "<unscopedPackageName>.api.md"
     */
    "reportFileName": "api-report.md",

    /**
     * The folder where the API report file is written.  The path is resolved relative to the folder of the config
     * file that contains the setting.
     *
     * DEFAULT VALUE: "<projectFolder>/etc/"
     */
    "reportFolder": "<projectFolder>/",

    /**
     * The temporary folder where the API report file is written.  The path is resolved relative to the folder of
     * the config file that contains the setting.
     *
     * After API Extractor is run, this file should be copied into the "reportFolder".  API Extractor does not
     * do this automatically.  This can be useful for CI workflows.
     *
     * DEFAULT VALUE: "<projectFolder>/temp/"
     */
    "reportTempFolder": "<projectFolder>/temp/"
  },

  /**
   * Configures how the doc model file (*.api.json) will be generated.
   */
  "docModel": {
    /**
     * (Required) Whether to generate a doc model file.
     *
     * DEFAULT VALUE: false
     */
    "enabled": true,

    /**
     * The output path for the doc model file.  The path is resolved relative to the folder of the config file
     * that contains the setting.
     *
     * DEFAULT VALUE: "<projectFolder>/temp/<unscopedPackageName>.api.json"
     */
    "apiJsonFilePath": "<projectFolder>/temp/<unscopedPackageName>.api.json"
  },

  /**
   * Configures how the .d.ts rollup file will be generated.
   */
  "dtsRollup": {
    /**
     * (Required) Whether to generate the .d.ts rollup file.
     *
     * DEFAULT VALUE: false
     */
    "enabled": false
  },

  /**
   * Configures how the tsdoc-metadata.json file will be generated.
   */
  "tsdocMetadata": {
    /**
     * Whether to generate the tsdoc-metadata.json file.
     *
     * DEFAULT VALUE: false
     */
    "enabled": false
  },

  /**
   * Configures how API Extractor validates API declarations.
   */
  "messages": {
    /**
     * Configures handling of diagnostic messages reported by API Extractor during its analysis.
     *
     * messageKey:  `ae-<message-identifier>`, see https://api-extractor.com/pages/messages/globals/
     *
     * DEFAULT VALUE: "none"
     */
    "compilerMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    },

    /**
     * Configures handling of messages reported by API Extractor during analysis.
     *
     * messageKey:  `ae-<message-identifier>`, see https://api-extractor.com/pages/messages/globals/
     *
     * DEFAULT VALUE: "none"
     */
    "extractorMessageReporting": {
      "default": {
        "logLevel": "warning"
      },

      /**
       * For the "ae-missing-release-tag" message, we log a warning because we want to ensure
       * that all public APIs have release tags. But we can set this to "none" if the project
       * is still in development and release tags are not required.
       */
      "ae-missing-release-tag": {
        "logLevel": "warning"
      },

      /**
       * For the "ae-unresolved-link" message, log as warning to catch broken documentation links.
       */
      "ae-unresolved-link": {
        "logLevel": "warning"
      }
    },

    /**
     * Configures handling of messages reported by the API Extractor during API review.
     */
    "tsdocMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    }
  }
}
