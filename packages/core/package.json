{
  "name": "@vizualni/core",
  "version": "0.1.0-beta.1",
  "description": "Framework-agnostic visualization library - core scales, layouts, and shapes",
  "type": "module",
  "license": "MIT",
  "author": "vizualni",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acailic/vizualni-admin.git",
    "directory": "packages/core"
  },
  "keywords": [
    "visualization",
    "charts",
    "d3",
    "data-viz",
    "framework-agnostic"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "api:extract": "api-extractor run --local --verbose",
    "api:check": "api-extractor run --verbose"
  },
  "dependencies": {
    "d3-array": "^3.2.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.47.0",
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.8",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
