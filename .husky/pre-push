#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run tests before pushing
echo "🧪 Running tests..."
if command -v npm &> /dev/null; then
  npm test
elif command -v yarn &> /dev/null; then
  yarn test
elif command -v pnpm &> /dev/null; then
  pnpm test
else
  echo "⚠️  No package manager found. Install npm, yarn, or pnpm."
  exit 1
fi

echo "✅ Tests passed!"