{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "urql": ["./graphql/urql-compat.ts"]
    },
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "incremental": false,
    "outDir": ".tsbuild",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": ["node_modules", "../node_modules", ".next"],
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", ".next/types/**/*.ts"]
}
