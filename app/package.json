      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.js"
    },
    "./connectors": {
      "types": "./dist/connectors/index.d.ts",
      "import": "./dist/connectors/index.mjs",
      "require": "./dist/connectors/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": true,
  "files": [
    "dist",
    "exports",
    "locales",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "funding": {
    "url": "https://github.com/sponsors/acailic"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:lib": "tsup && tsc --project tsconfig.dts.json && node scripts/copy-dts.js",
    "build:dts": "tsc --project tsconfig.dts.json && node scripts/copy-dts.js",
    "build:preconstruct": "preconstruct build",
    "start": "node server.js",
    "start:next": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "next build --analyze",
    "benchmark": "node benchmarks/chart-rendering.bench.ts && node benchmarks/data-loading.bench.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:focused": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "rm -rf .next out dist",
    "postbuild": "npm run build:lib"
  },
